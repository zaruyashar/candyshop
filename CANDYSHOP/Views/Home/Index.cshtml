@model CANDYSHOP.Models.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
    
    // Categorize products for menu tabs (case-insensitive with fallback of unmatched products to Sweets)
    var cakes = Model.Products.Where(p => 
        string.Equals(p.Category, "Cake", StringComparison.OrdinalIgnoreCase) || 
        string.Equals(p.Category, "Cupcake", StringComparison.OrdinalIgnoreCase) || 
        string.Equals(p.Category, "Tart", StringComparison.OrdinalIgnoreCase)
    ).ToList();

    var pastries = Model.Products.Where(p => 
        string.Equals(p.Category, "Pastry", StringComparison.OrdinalIgnoreCase)
    ).ToList();

    var sweets = Model.Products.Where(p => 
        !cakes.Contains(p) && !pastries.Contains(p)
    ).ToList();
}

@functions {
    string ResolveImageUrl(string? path, string defaultPath = "img/logo.png")
    {
        if (string.IsNullOrWhiteSpace(path))
            return Url.Content("~/lib-candy/pieceofcake_html/" + defaultPath);
        
        var cleanPath = path.Trim().Replace("\\", "/").TrimStart('/');
        
        if (cleanPath.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || 
            cleanPath.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            return cleanPath;
        }

        if (cleanPath.StartsWith("img/", StringComparison.OrdinalIgnoreCase))
        {
            cleanPath = "lib-candy/pieceofcake_html/" + cleanPath;
        }
        
        return Url.Content("~/" + cleanPath);
    }
}

