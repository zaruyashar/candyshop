@model CANDYSHOP.Models.Testimonial
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Testimonial";
}

<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <a href="@Url.Action("Testimonials", "Admin")" style="color:var(--muted)">Testimonials</a>
    <span class="sep">/</span>
    <span class="here">Add New</span>
  </div>
  <a href="@Url.Action("Testimonials", "Admin")" class="btn-ghost">
    <i class="fa-solid fa-arrow-left"></i> Back to list
  </a>
</div>

<div class="card">
  <div class="card-head"><i class="fa-solid fa-plus"></i> New Testimonial</div>
  <div class="card-body">
    <form asp-action="TestimonialCreate" method="post">
      @Html.AntiForgeryToken()
      
      <div class="form-grid">
        <div class="form-group">
          <label asp-for="ClientName">Client Name <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="ClientName" placeholder="e.g. Lana King" required>
          <span asp-validation-for="ClientName" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="Role">Role / Title <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="Role" placeholder="e.g. TV Star or Regular Customer" required>
          <span asp-validation-for="Role" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="ImagePath">Avatar Image Path <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="ImagePath" placeholder="e.g. img/testimonial1.jpg" required>
          <span asp-validation-for="ImagePath" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="Comment">Feedback Comment <span class="req">*</span></label>
          <textarea class="form-input" asp-for="Comment" rows="5" placeholder="Type the client feedback here..." required></textarea>
          <span asp-validation-for="Comment" style="color: var(--pink); font-size: 12px;"></span>
        </div>
      </div>

      <div class="form-actions">
        <a href="@Url.Action("Testimonials", "Admin")" class="btn-ghost"><i class="fa-solid fa-xmark"></i> Cancel</a>
        <button type="submit" class="btn-save"><i class="fa-solid fa-floppy-disk"></i> Create</button>
      </div>
    </form>
  </div>
</div>
