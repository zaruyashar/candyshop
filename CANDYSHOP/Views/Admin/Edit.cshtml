@model CANDYSHOP.Models.Product
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Product";
}

<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <a href="@Url.Action("Index", "Admin")" style="color:var(--muted)">Products</a>
    <span class="sep">/</span>
    <span class="here">Edit #@Model.Id</span>
  </div>
  <a href="@Url.Action("Index", "Admin")" class="btn-ghost">
    <i class="fa-solid fa-arrow-left"></i> Back to list
  </a>
</div>

<div class="card">
  <div class="card-head"><i class="fa-solid fa-pen-to-square"></i> Edit Product</div>
  <div class="card-body">
    <form asp-action="Edit" method="post" id="updateForm">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />
      
      <div class="form-grid">

        <div class="form-group">
          <label asp-for="Name">Name <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="Name" required>
          <span asp-validation-for="Name" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="Category">Category <span class="req">*</span></label>
          <select class="form-input" asp-for="Category" required>
            <option value="Cake">Cake</option>
            <option value="Cupcake">Cupcake</option>
            <option value="Cookie">Cookie</option>
            <option value="Pastry">Pastry</option>
            <option value="Dessert">Dessert</option>
            <option value="Tart">Tart</option>
          </select>
          <span asp-validation-for="Category" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="Price">Price ($) <span class="req">*</span></label>
          <input class="form-input" type="number" step="0.01" min="0" asp-for="Price" required>
          <span asp-validation-for="Price" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="Stock">Stock <span class="req">*</span></label>
          <input class="form-input" type="number" min="0" asp-for="Stock" required>
          <span asp-validation-for="Stock" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="Status">Status</label>
          <select class="form-input" asp-for="Status">
            <option value="Active">Active</option>
            <option value="Low">Low</option>
            <option value="Out">Out</option>
          </select>
          <span asp-validation-for="Status" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="ImageUrl">Image URL</label>
          <input class="form-input" type="text" asp-for="ImageUrl">
          <span asp-validation-for="ImageUrl" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="Description">Description</label>
          <textarea class="form-input" asp-for="Description"></textarea>
          <span asp-validation-for="Description" style="color: var(--pink); font-size: 12px;"></span>
        </div>
      </div>

      <div class="form-actions">
        <a href="@Url.Action("Index", "Admin")" class="btn-ghost"><i class="fa-solid fa-xmark"></i> Cancel</a>
        <button type="submit" class="btn-save"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
      </div>
    </form>
  </div>
</div>
