@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <span class="here">Dashboard</span>
  </div>
</div>

<div class="card" style="margin-bottom: 30px;">
  <div class="card-head">
     <i class="fa-solid fa-circle-nodes"></i> Administrative Center
  </div>
  <div class="card-body" style="padding: 30px 40px; display: flex; align-items: center; gap: 20px;">
     <div style="font-size: 64px;">🎂🧁✨</div>
     <div>
        <h2 style="font-family: 'Paytone One', sans-serif; color: var(--pink); margin-top: 0; margin-bottom: 10px;">Welcome to Piece of Cake CMS!</h2>
        <p style="font-size: 16px; margin: 0; color: var(--muted);">Here you can manage your shop products, update latest blog posts, review client testimonials, and read user messages dynamically.</p>
     </div>
  </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px;">
  
  <!-- Products Stat Card -->
  <div class="card" style="margin: 0;">
     <div class="card-body" style="padding: 25px; display: flex; justify-content: space-between; align-items: center;">
        <div>
           <h3 style="font-family: 'Paytone One', sans-serif; font-size: 32px; margin: 0; color: var(--teal);">@ViewBag.ProductCount</h3>
           <p style="margin: 5px 0 0 0; color: var(--muted); font-weight: 600;">Products</p>
        </div>
        <div style="font-size: 40px; color: var(--teal); opacity: 0.8;"><i class="fa-solid fa-cake-candles"></i></div>
     </div>
     <div style="background-color: var(--teal); height: 4px;"></div>
  </div>
  
  <!-- Blog Posts Stat Card -->
  <div class="card" style="margin: 0;">
     <div class="card-body" style="padding: 25px; display: flex; justify-content: space-between; align-items: center;">
        <div>
           <h3 style="font-family: 'Paytone One', sans-serif; font-size: 32px; margin: 0; color: var(--pink);">@ViewBag.BlogPostCount</h3>
           <p style="margin: 5px 0 0 0; color: var(--muted); font-weight: 600;">Blog Posts</p>
        </div>
        <div style="font-size: 40px; color: var(--pink); opacity: 0.8;"><i class="fa-solid fa-blog"></i></div>
     </div>
     <div style="background-color: var(--pink); height: 4px;"></div>
  </div>

  <!-- Testimonials Stat Card -->
  <div class="card" style="margin: 0;">
     <div class="card-body" style="padding: 25px; display: flex; justify-content: space-between; align-items: center;">
        <div>
           <h3 style="font-family: 'Paytone One', sans-serif; font-size: 32px; margin: 0; color: var(--teal);">@ViewBag.TestimonialCount</h3>
           <p style="margin: 5px 0 0 0; color: var(--muted); font-weight: 600;">Testimonials</p>
        </div>
        <div style="font-size: 40px; color: var(--teal); opacity: 0.8;"><i class="fa-solid fa-comment-dots"></i></div>
     </div>
     <div style="background-color: var(--teal); height: 4px;"></div>
  </div>

  <!-- Messages Stat Card -->
  <div class="card" style="margin: 0;">
     <div class="card-body" style="padding: 25px; display: flex; justify-content: space-between; align-items: center;">
        <div>
           <h3 style="font-family: 'Paytone One', sans-serif; font-size: 32px; margin: 0; color: var(--pink);">@ViewBag.MessageCount</h3>
           <p style="margin: 5px 0 0 0; color: var(--muted); font-weight: 600;">Inquiries (@ViewBag.UnreadCount unread)</p>
        </div>
        <div style="font-size: 40px; color: var(--pink); opacity: 0.8;"><i class="fa-solid fa-envelope"></i></div>
     </div>
     <div style="background-color: var(--pink); height: 4px;"></div>
  </div>

</div>

<div class="card">
   <div class="card-head"><i class="fa-solid fa-lightbulb"></i> Quick Actions</div>
   <div class="card-body" style="display: flex; gap: 15px; flex-wrap: wrap; padding: 20px;">
       <a href="@Url.Action("Products", "Admin")" class="btn-save" style="text-decoration: none; padding: 10px 20px; font-size: 14px; border-radius: 4px; display: inline-flex; align-items: center; gap: 5px;">
           <i class="fa-solid fa-cake-candles"></i> Manage Products
       </a>
       <a href="@Url.Action("BlogPosts", "Admin")" class="btn-save" style="text-decoration: none; padding: 10px 20px; font-size: 14px; border-radius: 4px; display: inline-flex; align-items: center; gap: 5px;">
           <i class="fa-solid fa-blog"></i> Manage Blog
       </a>
       <a href="@Url.Action("Testimonials", "Admin")" class="btn-save" style="text-decoration: none; padding: 10px 20px; font-size: 14px; border-radius: 4px; display: inline-flex; align-items: center; gap: 5px;">
           <i class="fa-solid fa-comment-dots"></i> Manage Testimonials
       </a>
       <a href="@Url.Action("Messages", "Admin")" class="btn-save" style="text-decoration: none; padding: 10px 20px; font-size: 14px; border-radius: 4px; display: inline-flex; align-items: center; gap: 5px;">
           <i class="fa-solid fa-envelope"></i> Read Messages
       </a>
   </div>
</div>
