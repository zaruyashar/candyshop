@model List<CANDYSHOP.Models.ContactMessage>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Messages";
}

<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <span class="here">Messages</span>
  </div>
</div>

<div class="card">
  <div class="card-head">
    <i class="fa-solid fa-envelope"></i> Contact Messages (@Model.Count(m => !m.IsRead) Unread)
  </div>
  <div class="card-body">
    <div class="table-wrap">
      <table class="data">
        <thead>
          <tr>
            <th>Date</th>
            <th>Name</th>
            <th>Email</th>
            <th>Subject</th>
            <th>Message</th>
            <th>Status</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody>
          @if (Model == null || !Model.Any())
          {
              <tr>
                  <td colspan="7" style="text-align:center;padding:30px;color:var(--muted)">No messages found.</td>
              </tr>
          }
          else
          {
              @foreach (var item in Model)
              {
                  <tr style="@(!item.IsRead ? "background-color: rgba(45, 187, 164, 0.05); font-weight: 600;" : "")" id="row-@item.Id">
                    <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.Name</td>
                    <td><a href="mailto:@item.Email" style="color: var(--teal)">@item.Email</a></td>
                    <td>@item.Subject</td>
                    <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Message">
                        @item.Message
                    </td>
                    <td>
                        @if (!item.IsRead)
                        {
                            <span class="pill pill-pink" id="badge-@item.Id">Unread</span>
                        }
                        else
                        {
                            <span class="pill pill-teal">Read</span>
                        }
                    </td>
                    <td style="text-align:right">
                      <div class="row-actions">
                        <a href="@Url.Action("MessageDetails", "Admin", new { id = item.Id })" class="btn-icon" title="View Details" style="background-color: var(--teal); color: white; display: inline-flex; align-items: center; justify-content: center; text-decoration: none;">
                          <i class="fa-solid fa-eye"></i>
                        </a>
                        <button class="btn-icon btn-delete btn-delete-msg" data-id="@item.Id" data-name="Message from @item.Name" title="Delete" style="background-color: var(--pink); color: white;">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
              }
          }
        </tbody>
      </table>
    </div>
  </div>
</div>

@section Scripts {
<script>


  // Delete message
  document.querySelectorAll(".btn-delete-msg").forEach(button => {
      button.addEventListener("click", () => {
          const id = button.dataset.id;
          const name = button.dataset.name;
          
          Swal.fire({
              title: `Delete this message?`,
              text: "This action cannot be undone.",
              icon: "warning",
              showCancelButton: true,
              confirmButtonColor: "#D0324B",
              cancelButtonColor: "#3d2230",
              confirmButtonText: "Yes, delete it!",
              background: "#FDF5E7"
          }).then(res => {
              if (res.isConfirmed) {
                  fetch(`@Url.Action("DeleteMessage", "Admin")/${id}`, {
                      method: "POST"
                  })
                  .then(response => response.json())
                  .then(data => {
                      if (data.success) {
                          Swal.fire({
                              title: "Deleted!",
                              icon: "success",
                              background: "#FDF5E7",
                              confirmButtonColor: "#2dbba4"
                          }).then(() => {
                              location.reload();
                          });
                      } else {
                          Swal.fire({
                              title: "Error!",
                              text: data.message || "Failed to delete message.",
                              icon: "error",
                              background: "#FDF5E7"
                          });
                      }
                  });
              }
          });
      });
  });
</script>
}
