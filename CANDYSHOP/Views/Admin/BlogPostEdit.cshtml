@model CANDYSHOP.Models.BlogPost
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit Blog Post";
}

<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <a href="@Url.Action("BlogPosts", "Admin")" style="color:var(--muted)">Blog Posts</a>
    <span class="sep">/</span>
    <span class="here">Edit #@Model.Id</span>
  </div>
  <a href="@Url.Action("BlogPosts", "Admin")" class="btn-ghost">
    <i class="fa-solid fa-arrow-left"></i> Back to list
  </a>
</div>

<div class="card">
  <div class="card-head"><i class="fa-solid fa-pen-to-square"></i> Edit Blog Post</div>
  <div class="card-body">
    <form asp-action="BlogPostEdit" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />
      <input type="hidden" asp-for="CreatedDate" />
      
      <div class="form-grid">
        <div class="form-group full">
          <label asp-for="Title">Title <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="Title" required>
          <span asp-validation-for="Title" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="Summary">Summary <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="Summary" required>
          <span asp-validation-for="Summary" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="ImagePath">Image Path <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="ImagePath" required>
          <span asp-validation-for="ImagePath" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="CommentCount">Comments Count</label>
          <input class="form-input" type="number" min="0" asp-for="CommentCount">
          <span asp-validation-for="CommentCount" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="Content">Full Content <span class="req">*</span></label>
          <textarea class="form-input" asp-for="Content" rows="10" required></textarea>
          <span asp-validation-for="Content" style="color: var(--pink); font-size: 12px;"></span>
        </div>
      </div>

      <div class="form-actions">
        <a href="@Url.Action("BlogPosts", "Admin")" class="btn-ghost"><i class="fa-solid fa-xmark"></i> Cancel</a>
        <button type="submit" class="btn-save"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
      </div>
    </form>
  </div>
</div>
