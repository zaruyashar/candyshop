@model List<CANDYSHOP.Models.Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Products";
}

<!-- Page head: title left, add new right -->
<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <span class="here">Products</span>
  </div>
  <a href="@Url.Action("Create", "Admin")" class="btn-add">
    <i class="fa-solid fa-plus"></i> Add New
  </a>
</div>

<!-- Card with table -->
<div class="card">
  <div class="card-head">
    <i class="fa-solid fa-table-list"></i> All Products
  </div>
  <div class="card-body">

    <!-- Tools row: length + search -->
    <div class="table-tools">
      <div class="len">
        <label>
          Show
          <select id="pageLen">
            <option selected>10</option>
            <option>25</option>
            <option>50</option>
          </select>
          entries
        </label>
      </div>
      <div class="search">
        <form method="get" action="@Url.Action("Products", "Admin")" style="display: flex; gap: 5px;">
            <input type="search" name="q" id="searchInput" placeholder="Search products..." value="@ViewBag.SearchQuery">
            <button type="submit" class="btn-save" style="padding: 5px 15px; font-size: 13px; border-radius: 4px;">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
            {
                <a href="@Url.Action("Products", "Admin")" class="btn-ghost" style="padding: 5px 10px; text-decoration: none; border-radius: 4px; display: flex; align-items: center;">Clear</a>
            }
        </form>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <table class="data" id="dataTable">
        <thead>
          <tr>
            <th style="cursor: pointer;" onclick="sortTable(0)"># <i class="fa-solid fa-sort"></i></th>
            <th style="cursor: pointer;" onclick="sortTable(1)">Name <i class="fa-solid fa-sort"></i></th>
            <th style="cursor: pointer;" onclick="sortTable(2)">Category <i class="fa-solid fa-sort"></i></th>
            <th style="cursor: pointer;" onclick="sortTable(3)">Price <i class="fa-solid fa-sort"></i></th>
            <th style="cursor: pointer;" onclick="sortTable(4)">Stock <i class="fa-solid fa-sort"></i></th>
            <th style="cursor: pointer;" onclick="sortTable(5)">Status <i class="fa-solid fa-sort"></i></th>
            <th style="text-align:right; cursor:default">Actions</th>
          </tr>
        </thead>
        <tbody id="tbody">
          @if (Model == null || !Model.Any())
          {
              <tr>
                  <td colspan="7" style="text-align:center;padding:30px;color:var(--muted)">No products found.</td>
              </tr>
          }
          else
          {
              @foreach (var item in Model)
              {
                  <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Name</strong></td>
                    <td>@item.Category</td>
                    <td>$@item.Price.ToString("0.00")</td>
                    <td>@item.Stock</td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="pill pill-teal">@item.Status</span>
                        }
                        else if (item.Status == "Low")
                        {
                            <span class="pill pill-cream">@item.Status</span>
                        }
                        else
                        {
                            <span class="pill pill-pink">@item.Status</span>
                        }
                    </td>
                    <td style="text-align:right">
                      <div class="row-actions">
                        <a href="@Url.Action("Edit", "Admin", new { id = item.Id })" class="btn-icon btn-edit" title="Edit">
                          <i class="fa-solid fa-pen"></i>
                        </a>
                        <button class="btn-icon btn-delete" data-id="@item.Id" data-name="@item.Name" title="Delete">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
              }
          }
        </tbody>
      </table>
    </div>

    <!-- Foot: info -->
    <div class="table-foot">
      <div id="info">Showing @(Model?.Count ?? 0) entries</div>
    </div>

  </div>
</div>

@section Scripts {
<script>
  // SweetAlert delete
  document.querySelectorAll(".btn-delete").forEach(button => {
      button.addEventListener("click", () => {
          const id = button.dataset.id;
          const name = button.dataset.name;
          
          Swal.fire({
              title: `Delete "${name}"?`,
              text: "This action cannot be undone.",
              icon: "warning",
              showCancelButton: true,
              confirmButtonColor: "#D0324B",
              cancelButtonColor: "#3d2230",
              confirmButtonText: "Yes, delete it!",
              background: "#FDF5E7"
          }).then(res => {
              if (res.isConfirmed) {
                  fetch(`@Url.Action("Delete", "Admin")/${id}`, {
                      method: "POST"
                  })
                  .then(response => response.json())
                  .then(data => {
                      if (data.success) {
                          Swal.fire({
                              title: "Deleted!",
                              icon: "success",
                              background: "#FDF5E7",
                              confirmButtonColor: "#2dbba4"
                          }).then(() => {
                              location.reload();
                          });
                      } else {
                          Swal.fire({
                              title: "Error!",
                              text: data.message || "Failed to delete product.",
                              icon: "error",
                              background: "#FDF5E7"
                          });
                      }
                  });
              }
          });
      });
  });

  // Client side sorting helper
  function sortTable(n) {
    var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
    table = document.getElementById("dataTable");
    switching = true;
    dir = "asc";
    while (switching) {
      switching = false;
      rows = table.rows;
      for (i = 1; i < (rows.length - 1); i++) {
        shouldSwitch = false;
        x = rows[i].getElementsByTagName("TD")[n];
        y = rows[i + 1].getElementsByTagName("TD")[n];
        
        var xVal = x.textContent || x.innerText;
        var yVal = y.textContent || y.innerText;
        
        // Parse numerical value if sorting ID, Price, or Stock columns
        if (n === 0 || n === 4) {
            xVal = parseInt(xVal) || 0;
            yVal = parseInt(yVal) || 0;
        } else if (n === 3) {
            xVal = parseFloat(xVal.replace('$', '')) || 0;
            yVal = parseFloat(yVal.replace('$', '')) || 0;
        } else {
            xVal = xVal.toLowerCase();
            yVal = yVal.toLowerCase();
        }

        if (dir == "asc") {
          if (xVal > yVal) {
            shouldSwitch = true;
            break;
          }
        } else if (dir == "desc") {
          if (xVal < yVal) {
            shouldSwitch = true;
            break;
          }
        }
      }
      if (shouldSwitch) {
        rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
        switching = true;
        switchcount ++;
      } else {
        if (switchcount == 0 && dir == "asc") {
          dir = "desc";
          switching = true;
        }
      }
    }
  }
</script>
}
