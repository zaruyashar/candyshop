@model CANDYSHOP.Models.BlogPost
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Blog Post";
}

<div class="page-head">
  <div class="crumbs">
    <i class="fa-solid fa-house" style="color:var(--pink)"></i>
    <span>Home</span>
    <span class="sep">/</span>
    <a href="@Url.Action("BlogPosts", "Admin")" style="color:var(--muted)">Blog Posts</a>
    <span class="sep">/</span>
    <span class="here">Add New</span>
  </div>
  <a href="@Url.Action("BlogPosts", "Admin")" class="btn-ghost">
    <i class="fa-solid fa-arrow-left"></i> Back to list
  </a>
</div>

<div class="card">
  <div class="card-head"><i class="fa-solid fa-plus"></i> New Blog Post</div>
  <div class="card-body">
    <form asp-action="BlogPostCreate" method="post">
      @Html.AntiForgeryToken()
      
      <div class="form-grid">
        <div class="form-group full">
          <label asp-for="Title">Title <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="Title" placeholder="e.g. Baking the Perfect Chocolate Cake" required>
          <span asp-validation-for="Title" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="Summary">Summary <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="Summary" placeholder="Short preview description..." required>
          <span asp-validation-for="Summary" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="ImagePath">Image Path <span class="req">*</span></label>
          <input class="form-input" type="text" asp-for="ImagePath" placeholder="e.g. img/blog1.jpg" required>
          <span asp-validation-for="ImagePath" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group">
          <label asp-for="CommentCount">Initial Comments Count</label>
          <input class="form-input" type="number" min="0" asp-for="CommentCount" value="0">
          <span asp-validation-for="CommentCount" style="color: var(--pink); font-size: 12px;"></span>
        </div>

        <div class="form-group full">
          <label asp-for="Content">Full Content <span class="req">*</span></label>
          <textarea class="form-input" asp-for="Content" rows="10" placeholder="Type the blog article content here..." required></textarea>
          <span asp-validation-for="Content" style="color: var(--pink); font-size: 12px;"></span>
        </div>
      </div>

      <div class="form-actions">
        <a href="@Url.Action("BlogPosts", "Admin")" class="btn-ghost"><i class="fa-solid fa-xmark"></i> Cancel</a>
        <button type="submit" class="btn-save"><i class="fa-solid fa-floppy-disk"></i> Create</button>
      </div>
    </form>
  </div>
</div>
